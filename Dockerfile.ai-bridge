FROM rust:1.85-bookworm AS build

WORKDIR /app

COPY . .

RUN cargo build --manifest-path apps/ai-bridge/Cargo.toml --release

FROM debian:bookworm-slim AS runtime

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV PORT=8795
ENV HUMAN_AGENT_PLAYGROUND_AI_BRIDGE_DATA_PATH=/data/restflow.db

COPY --from=build /app/target/release/human-agent-playground-ai-bridge /usr/local/bin/human-agent-playground-ai-bridge

EXPOSE 8795

CMD ["human-agent-playground-ai-bridge"]
