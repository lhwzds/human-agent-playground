FROM node:22-bookworm-slim

WORKDIR /app

COPY . .

RUN find . -name '*.tsbuildinfo' -delete
RUN npm install --ignore-scripts

ENV PORT=8790
ENV HUMAN_AGENT_PLAYGROUND_DATA_PATH=/data/sessions.json

COPY docker/dev-entrypoint.sh /usr/local/bin/hap-dev-entrypoint.sh
RUN chmod +x /usr/local/bin/hap-dev-entrypoint.sh

EXPOSE 8790 4178

CMD ["/usr/local/bin/hap-dev-entrypoint.sh"]
