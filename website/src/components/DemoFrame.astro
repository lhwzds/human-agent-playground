---
interface Props {
  demoUrl: string
}

const { demoUrl } = Astro.props
const hasLiveDemo = demoUrl.length > 0
---

<section class="demo-shell" id="demo">
  <div class="browser-chrome">
    <div class="browser-lights" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <p>{hasLiveDemo ? demoUrl : 'Live demo URL pending deployment'}</p>
  </div>

  {
    hasLiveDemo ? (
      <iframe
        src={demoUrl}
        title="Human Agent Playground live demo"
        loading="lazy"
        allow="clipboard-write"
      ></iframe>
    ) : (
      <div class="demo-fallback">
        <img
          src="/xiangqi-session-example.png"
          alt="A finished shared Xiangqi session with the board, move feed, and session controls."
        />
        <div class="demo-fallback-copy">
          <strong>Live demo target not configured yet.</strong>
          <p>
            Set <code>PUBLIC_DEMO_URL</code> at build time to embed the running app.
            Until then, this landing page shows a real captured session from the current interface.
          </p>
        </div>
      </div>
    )
  }
</section>
